# .htaccess for CFCI Church Website

# ----------------------------------------------------------------------
# General Configuration
# ----------------------------------------------------------------------

# Ensure UTF-8 Encoding
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddCharset UTF-8 .html .php .css .js
</IfModule>

# Prevent Directory Listings
Options -Indexes

# ----------------------------------------------------------------------
# Custom Error Pages
# ----------------------------------------------------------------------
ErrorDocument 403 /error.php?code=403
ErrorDocument 404 /error.php?code=404
ErrorDocument 500 /error.php?code=500

# ----------------------------------------------------------------------
# URL Rewriting (Clean URLs)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set RewriteBase - Update this based on your actual path
    RewriteBase /CFCI_Church_Website/
    
    # Force HTTPS (Uncomment when ready for production)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Redirect non-www to www (or vice versa based on preference)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Rewrite rules for PHP files to remove .php extension
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]
    
    # Redirect index.php to root
    RewriteCond %{THE_REQUEST} /index\.php [NC]
    RewriteRule ^(.*)index\.php$ /$1 [L,R=301,NC]
</IfModule>

# ----------------------------------------------------------------------
# Security Rules - Allow PHP includes but block direct access
# ----------------------------------------------------------------------
# Allow PHP includes from the includes/ directory
<Files ~ "\.(php|inc)$">
    Order allow,deny
    Allow from all
</Files>

# Block direct access to specific sensitive files
<FilesMatch "\.(sql|env|htaccess|htpasswd|ini|log|sh|bak|save)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Allow access to config files from PHP includes but not direct browser access
RewriteRule ^config/.*\.php$ - [F,NC]
RewriteRule ^includes/.*\.php$ - [F,NC]

# ----------------------------------------------------------------------
# Browser Caching
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    <FilesMatch "\.(js|css|json|xml|txt|ico)$">
        ExpiresDefault "access plus 1 week"
    </FilesMatch>
    
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp)$">
        ExpiresDefault "access plus 1 month"
    </FilesMatch>
    
    <FilesMatch "\.(mp4|mov|ogg|webm|mp3|wav)$">
        ExpiresDefault "access plus 1 month"
    </FilesMatch>
</IfModule>

# ----------------------------------------------------------------------
# Compression
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>